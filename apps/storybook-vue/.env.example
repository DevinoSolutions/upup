# Cloud-drive OAuth credentials for the Storybook cloud-drive stories.
# Copy this file to `.env.local` (gitignored) and fill in real values to enable
# genuine OAuth sign-in for Google Drive / OneDrive / Dropbox / Box.
#
# All vars MUST be VITE_-prefixed to reach the browser bundle. Any provider you
# leave blank still renders its real "Sign in with <provider>" screen (it just
# can't complete the OAuth round-trip). Read by packages/storybook-config/src/cloudDrives.ts.
#
# Add this Storybook's origin (http://localhost:53051) to each provider's list of
# authorized JavaScript origins / redirect URIs in its developer console.

# Google Drive — Google Cloud console (OAuth client ID + API key + project number)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=
VITE_GOOGLE_APP_ID=

# OneDrive — Azure app registration (Application/client ID). redirectUri defaults to window origin.
VITE_ONEDRIVE_CLIENT_ID=
VITE_ONEDRIVE_REDIRECT_URI=

# Dropbox — Dropbox app console (App key). redirectUri defaults to window origin.
VITE_DROPBOX_CLIENT_ID=
VITE_DROPBOX_REDIRECT_URI=

# Box — Box developer console (Client ID). redirectUri defaults to window origin.
VITE_BOX_CLIENT_ID=
VITE_BOX_REDIRECT_URI=
