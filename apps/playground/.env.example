# Playground (apps/playground) — cloud drive credentials
# =====================================================
# The playground renders a live <UpupUploader>. If you want the Google
# Drive / OneDrive / Dropbox / Box source tiles to be clickable in the
# preview, set the corresponding NEXT_PUBLIC_*_CLIENT_ID env var below.
#
# Sources without a client id stay visible in the sidebar but render
# GREYED OUT with a tooltip — so a first-time visitor can see every
# supported drive even if they haven't configured credentials yet.
#
# Copy this file to `.env.local` and fill in the ids you have. Leaving
# a var blank is equivalent to not setting it — that drive will stay
# greyed out.

# --- Google Drive ---
# Console: https://console.cloud.google.com → APIs & Services → OAuth 2.0 Client IDs
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=
NEXT_PUBLIC_GOOGLE_APP_ID=

# --- OneDrive ---
# Console: https://portal.azure.com → App registrations
NEXT_PUBLIC_ONEDRIVE_CLIENT_ID=

# --- Dropbox ---
# Console: https://www.dropbox.com/developers/apps
NEXT_PUBLIC_DROPBOX_CLIENT_ID=

# --- Box ---
# Console: https://app.box.com/developers/console
NEXT_PUBLIC_BOX_CLIENT_ID=

# --- Optional: Server Mode demo backend base URL ---
# If you mount `@upupjs/server` under a known path on the host, set this
# so the "Server Mode" preset wires through your real handler. Defaults
# to `/api/upup` which works with Next.js App Router conventions.
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# =====================================================
# Server Mode (src/app/api/upup) — SERVER-ONLY, never sent to the browser
# =====================================================
# The playground defaults to a zero-config MOCK mode, so this whole section can
# stay blank for `pnpm dev`. Flip the uploader to real storage (hides the
# "MOCK MODE" banner and uploads for real) with:
# NEXT_PUBLIC_UPUP_USE_REAL_STORAGE=true

# --- HMAC upload-token secret (REQUIRED once the real /api/upup route loads) ---
# There is NO default in code: the route refuses to construct without this, so a
# deploy that forgets it fails fast BY NAME instead of booting on a public
# secret. Generate a strong value, e.g.  openssl rand -hex 32  (min length 16).
# Leave this BLANK — copying a real secret into a committed example file would
# re-introduce exactly the shared-secret problem this guards against.
UPUP_UPLOAD_TOKEN_SECRET=

# --- S3 / S3-compatible storage (only needed in real-storage mode) ---
S3_BUCKET=
S3_REGION=
S3_KEY_ID=
S3_SECRET=
S3_ENDPOINT=

# --- Server-mode cloud-drive OAuth secrets (optional) ---
# The client IDs above are public (NEXT_PUBLIC_*). These matching SECRETS are
# server-only and enable server-mode drive transfer. Absent = that drive is
# simply not configured for server mode (no opaque blank-secret failure).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DROPBOX_CLIENT_ID=
DROPBOX_APP_SECRET=
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=

# --- Escape hatch (dev only, NEVER production) ---
# Set this to the EXACT acknowledgement value to skip all required-env
# validation above and boot with broken/insecure behavior (prints a loud
# console warning). Any other value does nothing.
# DANGEROUSLY_BOOT_WITH_MISSING_REQUIRED_ENV_AND_SKIP_VALIDATION=I_UNDERSTAND_THIS_MAY_CRASH_CORRUPT_DATA_OR_EXPOSE_BROKEN_BEHAVIOR
