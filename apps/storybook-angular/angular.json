{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "storybook-angular": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": ".storybook",
            "port": 53054,
            "compodoc": false,
            "styles": [
              "../../packages/angular/dist/tailwind-prefixed.css",
              "../../packages/storybook-config/src/brand.css",
              "src/tailwind.css"
            ]
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": ".storybook",
            "outputDir": "storybook-static",
            "compodoc": false,
            "styles": [
              "../../packages/angular/dist/tailwind-prefixed.css",
              "../../packages/storybook-config/src/brand.css",
              "src/tailwind.css"
            ]
          }
        }
      }
    }
  }
}
