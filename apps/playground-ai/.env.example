# LLM provider key — pick one based on the model you set in src/mastra/agents/playground-agent.ts
ANTHROPIC_API_KEY=

# Server (defaults: localhost:4111 in dev)
MASTRA_HOST=0.0.0.0
PORT=4111

# CORS — comma-separated list of origins allowed to call /chat
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Auth — HMAC secret used by the playground to sign short-lived origin tokens
ORIGIN_TOKEN_SECRET=

# Cost guard — daily USD cap; over the cap the chat endpoint returns 503
DAILY_COST_CAP_USD=25

LOG_LEVEL=info
