{
  "name": "@upup/storybook-react",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "storybook": "storybook dev -p 53050 --no-open",
    "build-storybook": "storybook build -o storybook-static && node scripts/compose-vue.mjs",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@upup/core": "workspace:*",
    "@upup/react": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@upup/storybook-config": "workspace:*",
    "storybook": "^9",
    "@storybook/react-vite": "^9",
    "@storybook/addon-docs": "^9",
    "@storybook/addon-a11y": "^9",
    "@storybook/addon-themes": "^9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "msw": "^2.7.0",
    "msw-storybook-addon": "^2.0.4",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.2",
    "vitest": "^4.1.2"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}