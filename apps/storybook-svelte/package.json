{
    "name": "@useupup/storybook-svelte",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "storybook": "storybook dev -p 53052 --no-open",
        "build-storybook": "storybook build -o storybook-static",
        "test": "vitest run --passWithNoTests",
        "typecheck": "svelte-check --tsconfig ./tsconfig.json"
    },
    "dependencies": {
        "@useupup/core": "workspace:*",
        "@useupup/svelte": "workspace:*",
        "svelte": "^5.0.0"
    },
    "devDependencies": {
        "@useupup/storybook-config": "workspace:*",
        "storybook": "^9",
        "@storybook/svelte-vite": "^9",
        "@storybook/addon-docs": "^9",
        "@storybook/addon-a11y": "^9",
        "@storybook/addon-themes": "^9",
        "@sveltejs/vite-plugin-svelte": "^6.0.0",
        "msw": "^2.7.0",
        "msw-storybook-addon": "^2.0.4",
        "@tailwindcss/forms": "^0.5.7",
        "@tailwindcss/typography": "^0.5.16",
        "autoprefixer": "^10.4.20",
        "postcss": "^8.5.2",
        "tailwindcss": "^3.4.17",
        "typescript": "^5.3.2",
        "vite": "^7",
        "svelte-check": "^4.1.0",
        "vitest": "^4.1.2"
    },
    "msw": {
        "workerDirectory": [
            "public"
        ]
    }
