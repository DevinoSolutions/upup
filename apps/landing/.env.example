# Landing (apps/landing) — environment template
# =====================================================
# Copy to `.env.local` and fill in the values you have. Client vars
# (NEXT_PUBLIC_*) are inlined into the browser bundle; the server vars below
# are read only by the mounted @upupjs/server route and never sent to the client.
#
# The marketing pages render with zero env. Only the upload route
# (src/app/api/upup/[...path]/route.ts) requires the server secret below — it
# fails fast by name if the secret is missing, rather than booting on a public
# default.

# --- Client: cloud-drive tiles (public client IDs) ---
# A source without an id stays visible but greyed out with a tooltip.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=
NEXT_PUBLIC_GOOGLE_APP_ID=
NEXT_PUBLIC_ONEDRIVE_CLIENT_ID=
NEXT_PUBLIC_DROPBOX_CLIENT_ID=

# --- Client: misc ---
# If set, the uploader targets `${NEXT_PUBLIC_BASE_URL}/api/upup`; otherwise it
# uses the relative `/api/upup` on the current origin.
# NEXT_PUBLIC_BASE_URL=https://your-landing-host
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# --- Client: analytics dataset (PostHog) ---
# Selects which PostHog project (if any) the browser sends events to. Mirror the
# server POSTHOG_DATASET at build time. One of: production | e2e | disabled.
# Unset -> production when NEXT_PUBLIC_POSTHOG_KEY exists, else disabled.
# NEXT_PUBLIC_POSTHOG_DATASET=
# e2e-only credentials (used ONLY when the dataset resolves to 'e2e'):
# NEXT_PUBLIC_POSTHOG_E2E_TEST_PROJECT_HOST=
# NEXT_PUBLIC_POSTHOG_E2E_TEST_PROJECT_CAPTURE_TOKEN=

# =====================================================
# Server Mode (src/app/api/upup) — SERVER-ONLY, never sent to the browser
# =====================================================

# --- HMAC upload-token secret (REQUIRED once the /api/upup route loads) ---
# There is NO default in code: the route refuses to construct without this, so a
# deploy that forgets it fails fast BY NAME instead of booting on a public
# secret. Generate a strong value, e.g.  openssl rand -hex 32  (min length 16).
# Leave this BLANK — a committed example must never carry a working secret.
UPUP_UPLOAD_TOKEN_SECRET=

# --- S3 / S3-compatible storage (needed for real uploads) ---
S3_BUCKET=
S3_REGION=
S3_KEY_ID=
S3_SECRET=
S3_ENDPOINT=

# --- Server-mode cloud-drive OAuth secrets (optional) ---
# Matching server-only secrets for the public client IDs above. Absent = that
# drive is simply not configured for server-mode transfer (no opaque failure).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DROPBOX_CLIENT_ID=
DROPBOX_APP_SECRET=
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=

# --- Support/feedback flow (all optional) ---
# Analytics dataset selector (server side). One of: production | e2e | disabled.
# Unset -> production when a PostHog key exists, else disabled.
POSTHOG_DATASET=
# Numeric project id used ONLY by test scripts to verify e2e ingestion (never
# read by app code).
POSTHOG_E2E_TEST_PROJECT_ID=
# SMTP connection string for the support-email leg (e.g. smtp://user:pass@host:port).
# Absent -> the email leg reports 'not_configured' and only PostHog records the request.
SMTP_URL=
# Destination + sender for support emails (sensible placeholders apply if unset).
SUPPORT_EMAIL_TO=
SUPPORT_EMAIL_FROM=

# --- Escape hatch (dev only, NEVER production) ---
# Set this to the EXACT acknowledgement value to skip all required-env
# validation above and boot with broken/insecure behavior (prints a loud
# console warning). Any other value does nothing.
# DANGEROUSLY_BOOT_WITH_MISSING_REQUIRED_ENV_AND_SKIP_VALIDATION=I_UNDERSTAND_THIS_MAY_CRASH_CORRUPT_DATA_OR_EXPOSE_BROKEN_BEHAVIOR
