# LLM provider key — set the one matching the model in src/mastra/agents/playground-agent.ts
# Default model is openrouter/anthropic/claude-haiku-4.5, so OPENROUTER_API_KEY is what's needed.
OPENROUTER_API_KEY=

# Alternative providers (only set if you change the agent's model):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Server (defaults: localhost:4111 in dev)
MASTRA_HOST=0.0.0.0
PORT=4111

# CORS — comma-separated list of origins allowed to call the API.
# Unset = local-dev fallback (localhost:3000/4321/5173).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Auth — HMAC secret used by the playground to sign short-lived origin tokens.
# Unset = auth disabled (fine for dev). Required in production.
ORIGIN_TOKEN_SECRET=

# Rate limit (per IP, token bucket).
RATE_LIMIT_CAPACITY=30
RATE_LIMIT_WINDOW_MS=60000

# Daily request budget — when reached, /api/agents/* returns 503.
DAILY_REQUEST_CAP=5000

LOG_LEVEL=info

# PostHog AI-tracing export (names only — never commit real values).
# Dataset picks which project receives traces: production | e2e | disabled.
# Unset with no POSTHOG_KEY -> disabled (exporter never constructed).
POSTHOG_DATASET=
# Production project (used when dataset resolves to `production`).
POSTHOG_KEY=
POSTHOG_HOST=
# Separate e2e test project (used ONLY when dataset is `e2e`).
POSTHOG_E2E_TEST_PROJECT_CAPTURE_TOKEN=
POSTHOG_E2E_TEST_PROJECT_HOST=
