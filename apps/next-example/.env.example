# next-example (apps/next-example) — environment template
# =====================================================
# This app always runs in server mode against an S3-compatible store (MinIO in
# local dev). Copy to `.env.local` and fill in the values, OR rely on the
# `pnpm dev` script, which sources `local-dev/.env.minio` via dotenv.
#
# The pages render with zero env; only the upup route (app/api/upup/[...path]/
# route.ts, via lib/upup-config.ts) requires the credentials + secret below —
# a missing one fails fast BY NAME rather than booting on a committed default.
#
# NOTE: because `pnpm dev` loads `local-dev/.env.minio`, that file must ALSO
# define UPUP_UPLOAD_TOKEN_SECRET now that the silent default is gone (see the
# example at local-dev/.env.minio.example).

# --- HMAC upload-token secret (REQUIRED) ---
# No default in code. Generate a strong value, e.g.  openssl rand -hex 32
# (min length 16). Leave BLANK here — never commit a working secret.
UPUP_UPLOAD_TOKEN_SECRET=

# --- MinIO / S3 credentials (REQUIRED) ---
# Match local-dev/.env.minio. No silent defaults: a missing credential fails
# fast instead of quietly connecting with a guessable dev login.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# --- Non-secret MinIO conveniences (optional; defaults shown) ---
# These keep their defaults and mirror local-dev/.env.minio.example. MinIO runs
# on :9100 in this repo — never :9000 (another instance may occupy those ports).
# UPUP_E2E_BUCKET=upup-e2e
# UPUP_E2E_REGION=us-east-1
# UPUP_E2E_ENDPOINT=http://localhost:9100

# --- Escape hatch (dev only, NEVER production) ---
# Set this to the EXACT acknowledgement value to skip all required-env
# validation above and boot with broken/insecure behavior (prints a loud
# console warning). Any other value does nothing.
# DANGEROUSLY_BOOT_WITH_MISSING_REQUIRED_ENV_AND_SKIP_VALIDATION=I_UNDERSTAND_THIS_MAY_CRASH_CORRUPT_DATA_OR_EXPOSE_BROKEN_BEHAVIOR
