# local-dev/.env.test.example — cloud-drive SANDBOX credentials template.
#
# Copy to local-dev/.env.test (gitignored) and fill in per provider. You only
# need the providers you actually want to exercise; any provider left blank is
# skipped GREEN by the live suite (never a failure). See the full walkthrough
# in docs/drive-sandbox-setup.md.
#
# These are DISPOSABLE SANDBOX accounts — never production creds, never a real
# user's account. Obtain the refresh tokens once with:
#   node scripts/drive-sandbox/mint.mjs <provider>
# then seed fixtures with:
#   node scripts/drive-sandbox/seed.mjs all
# and run the live suite with:
#   pnpm run drive:sandbox:test
#
# In CI these live as repo GitHub Actions secrets (same names), consumed only
# by nightly.yml's Drive-Sandbox job.

# Master switch — the live integration suite is inert unless this is exactly 1,
# even if secrets are present. Keeps `pnpm test` hermetic.
UPUP_DRIVE_SANDBOX=1

# ── Box — Client Credentials Grant (service account; no refresh token) ────────
# Box dev app → "Client Credentials Grant", authorized in the admin console.
# App scopes must include read + write of all files.
UPUP_TEST_BOX_CLIENT_ID=
UPUP_TEST_BOX_CLIENT_SECRET=
UPUP_TEST_BOX_ENTERPRISE_ID=

# ── Dropbox — scoped app, App Folder access, offline (non-expiring) refresh ───
UPUP_TEST_DROPBOX_APP_KEY=
UPUP_TEST_DROPBOX_APP_SECRET=
UPUP_TEST_DROPBOX_REFRESH_TOKEN=

# ── Google Drive — OAuth client (Desktop or Web), drive.file scope ────────────
# Unverified "In production" consent screen is fine for drive.file (non-sensitive).
UPUP_TEST_GDRIVE_CLIENT_ID=
UPUP_TEST_GDRIVE_CLIENT_SECRET=
UPUP_TEST_GDRIVE_REFRESH_TOKEN=

# ── OneDrive — MS identity app, Files.ReadWrite + offline_access ──────────────
# Personal MS account → tenant "consumers" (default if unset).
# NOTE: the refresh token ROTATES on every use. Local runs consume it (re-mint
# when it goes stale); the nightly CI job rotates + writes it back automatically
# (needs the GH_SECRETS_WRITE_PAT secret — see the runbook).
UPUP_TEST_ONEDRIVE_CLIENT_ID=
UPUP_TEST_ONEDRIVE_CLIENT_SECRET=
UPUP_TEST_ONEDRIVE_REFRESH_TOKEN=
UPUP_TEST_ONEDRIVE_TENANT=consumers
