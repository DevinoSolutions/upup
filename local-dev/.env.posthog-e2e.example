# Shared PostHog E2E project credentials (#Shared_Apps_E2E_Testing, one project
# for ALL Devino apps' automated tests — synthetic data only, never production).
#
# Copy to local-dev/.env.posthog-e2e (gitignored) and fill in real values, OR
# provide these as CI secrets. NAMES ONLY here — never commit real values.
#
# The landing webServer + mastra read the capture token/host to SEND e2e events;
# the ingestion-verification spec reads the query key to VERIFY they landed.

# Which project the app runtimes talk to. For an e2e run this is `e2e`.
POSTHOG_DATASET=e2e

# Capture (write) credentials — used ONLY when the dataset resolves to `e2e`.
# The landing browser + its server route read these NEXT_PUBLIC_ names. Mastra
# (server) reads the NON-prefixed POSTHOG_E2E_TEST_PROJECT_{CAPTURE_TOKEN,HOST};
# the thumbs-flow harness maps the NEXT_PUBLIC_ values across when it boots
# mastra, so defining only the NEXT_PUBLIC_ pair here is sufficient locally.
NEXT_PUBLIC_POSTHOG_E2E_TEST_PROJECT_HOST=
NEXT_PUBLIC_POSTHOG_E2E_TEST_PROJECT_CAPTURE_TOKEN=

# Numeric project id — the ingestion Query API path is /api/projects/<id>/query.
POSTHOG_E2E_TEST_PROJECT_ID=

# Read-only query key (personal API key, query:read scope ONLY). User-provisioned
# and intentionally absent until supplied — the ingestion-verification spec skips
# GREEN (with a loud notice) without it, and a present-but-invalid key REDS. This
# test-only credential must NEVER ride a production/disabled runtime: the dataset
# isolation guard (apps/landing dataset.ts, apps/mastra observability.ts) throws
# by name if it is present on any non-e2e runtime.
# POSTHOG_E2E_TEST_PROJECT_QUERY_READ_ONLY_PERSONAL_API_KEY=
