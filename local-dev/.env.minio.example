# Copy to local-dev/.env.minio (gitignored) and fill in the blanks.
# The pnpm e2e:minio:* scripts load this file via dotenv-cli.

# MinIO root credentials (also used as the S3 access key/secret by the harness + node tests)
MINIO_ROOT_USER=upupadmin
MINIO_ROOT_PASSWORD=upupadmin123

# Bucket + region for the validation run
UPUP_E2E_BUCKET=upup-e2e
UPUP_E2E_REGION=us-east-1

# S3 endpoint the harness signs against and the node tests connect to.
# Must be the host the browser can also reach (presigned URLs point here).
UPUP_E2E_ENDPOINT=http://localhost:9000

# Host ports MinIO publishes. Override if 9000/9001 are already taken on your
# machine (e.g. another MinIO). If you change UPUP_MINIO_API_PORT, update
# UPUP_E2E_ENDPOINT above to match.
UPUP_MINIO_API_PORT=9000
UPUP_MINIO_CONSOLE_PORT=9001

# Gate for the node integration suite: "1" runs it; unset/absent skips it
# (so normal `pnpm test` / pre-commit stays green).
UPUP_E2E_MINIO=1

# Harness presign/transfer server (live path C / OAuth). SERVER-ONLY secret —
# never expose as a VITE_* var. Use the SAME Google client as storybook's
# VITE_GOOGLE_CLIENT_ID; the secret is the matching client secret.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Browser origin(s) allowed to call the harness. Comma-separated for the
# cross-framework e2e gate (all six storybooks). The gate also injects all six
# automatically, so this single default is fine for the manual svelte workflow.
UPUP_E2E_STORYBOOK_ORIGIN=http://localhost:53052

# Optional: restrict MinIO browser CORS (default "*").
MINIO_CORS_ORIGINS=*
