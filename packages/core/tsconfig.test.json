{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": true,
        "declaration": false,
        "declarationMap": false,
        "rootDir": ".",
        "types": ["vitest/globals", "node"],
        "paths": {
            "@useupup/core/contracts": ["./src/contracts.ts"],
            "@useupup/core/internal": ["./src/internal.ts"],
            "@useupup/core/i18n": ["./src/i18n/index.ts"],
            "@useupup/core/theme": ["./src/theme/index.ts"],
            "@useupup/core/strategies": ["./src/strategies/index.ts"],
            "@useupup/core": ["./src/index.ts"]
        }
    },
    "include": ["src", "tests"]
}
