{
  "name": "@upup/vanilla",
  "version": "2.2.0",
  "description": "Framework-free DOM file uploader (lit-html) with cloud-drive sources, resumable uploads, theming, and ICU i18n.",
  "repository": "https://github.com/DevinoSolutions/upup",
  "license": "MIT",
  "type": "module",
  "sideEffects": ["./dist/element.js", "./dist/element.cjs", "*.css"],
  "engines": { "node": ">=20" },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./element": {
      "types": "./dist/element.d.ts",
      "import": "./dist/element.js",
      "require": "./dist/element.cjs"
    },
    "./styles": "./dist/tailwind-prefixed.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup && pnpm run build:css",
    "build:css": "postcss src/tailwind.css -o ./dist/tailwind-prefixed.css",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/virtual-core": "^3.13.0",
    "@upup/core": "workspace:*",
    "lit-html": "^3.2.0"
  },
  "devDependencies": {
    "@upup/tailwind-config": "workspace:*",
    "jsdom": "22.1.0",
    "postcss": "^8.5.2",
    "postcss-cli": "^11.0.1",
    "tsup": "^8.4.0",
    "typescript": "^5.3.2",
    "vitest": "^4.1.2"
  }
}
