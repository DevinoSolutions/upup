{
  "name": "@upup/solid",
  "version": "2.2.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/styles.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node ./scripts/copy-styles.cjs",
    "build-storybook": "storybook build -o storybook-static",
    "dev": "tsup --watch --onSuccess \"node ./scripts/copy-styles.cjs\"",
    "storybook": "storybook dev -p 6011 --no-open",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "pnpm run build && pnpm publish --access public --no-git-checks",
    "test-release": "pnpm run build && pnpm publish --dry-run --access public --no-git-checks"
  },
  "dependencies": {
    "@upup/core": "workspace:*",
    "@upup/vanilla": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "jsdom": "22.1.0",
    "solid-js": "^1.9.13",
    "storybook-solidjs-vite": "^10.1.1",
    "tsup": "^8.4.0",
    "typescript": "^5.3.2",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.2"
  }
}
