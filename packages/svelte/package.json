{
  "name": "@upup/svelte",
  "version": "2.2.0",
  "description": "Svelte 5 file uploader with cloud-drive sources, resumable uploads, theming, and ICU i18n.",
  "repository": "https://github.com/DevinoSolutions/upup",
  "license": "MIT",
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles": "./dist/tailwind-prefixed.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "svelte-package --input src --output dist && pnpm run build:css",
    "build:css": "postcss src/tailwind.css -o ./dist/tailwind-prefixed.css",
    "dev": "svelte-package --input src --output dist --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "release": "pnpm run build && pnpm publish --access public --no-git-checks",
    "test-release": "pnpm run build && pnpm publish --dry-run --access public --no-git-checks"
  },
  "dependencies": {
    "@tanstack/svelte-virtual": "^3.13.0",
    "@upup/core": "workspace:*",
    "clsx": "^2.1.1",
    "load-script": "^2.0.0",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@testing-library/svelte": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "22.1.0",
    "postcss": "^8.5.2",
    "postcss-cli": "^11.0.1",
    "postcss-prefix-selector": "^2.1.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.2",
    "vite": "^7",
    "vitest": "^4.1.2"
  }
}
