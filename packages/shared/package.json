{
  "name": "@upup/shared",
  "version": "2.0.0",
  "private": false,
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "files": ["dist"],
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.3.2",
    "vitest": "^3.0.0"
  }
}
