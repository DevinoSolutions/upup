{
  "name": "upup",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "turbo run build",
    "build:landing": "turbo run build --filter=@upup/landing",
    "build:docs": "turbo run build --filter=docs",
    "build:package": "pnpm --filter upup-react-file-uploader run build",
    "clean": "turbo run clean",
    "dev": "dotenv -e local-dev/.env.ports -- concurrently \"pnpm run dev:apps\" \"pnpm run dev:package-watch\"",
    "dev:apps": "turbo run dev --parallel --filter=@upup/landing --filter=docs",
    "dev:playground": "pnpm --filter @upup/playground run dev",
    "build:playground": "turbo run build --filter=@upup/playground",
    "start:playground": "pnpm --filter @upup/playground run start",
    "dev:package-watch": "pnpm --filter upup-react-file-uploader run dev:build",
    "dev:all": "turbo run dev --parallel",
    "dev:package": "dotenv -e local-dev/.env.ports -- pnpm --filter upup-react-file-uploader run dev",
    "lint": "turbo run lint",
    "prettier-check": "pnpm --filter upup-react-file-uploader exec prettier --check \"src/**/*.{ts,tsx}\"",
    "prettier-write": "pnpm --filter upup-react-file-uploader exec prettier --write \"src/**/*.{ts,tsx}\"",
    "docs:build": "pnpm --filter docs run build",
    "start": "pnpm run docs:build && pnpm --filter @upup/landing run start",
    "dev:server": "pnpm --filter upup-react-file-uploader exec node server/index.js",
    "test": "turbo run test",
    "test:coverage": "pnpm --filter upup-react-file-uploader exec jest --coverage --coverageDirectory ../../coverage",
    "test:e2e": "pnpm --filter upup-react-file-uploader run test:e2e",
    "test:e2e:ui": "pnpm --filter upup-react-file-uploader run test:e2e:ui",
    "typecheck": "turbo run typecheck",
    "playwright:install": "pnpm --filter upup-react-file-uploader run playwright:install",
    "release": "pnpm --filter upup-react-file-uploader run release",
    "size": "size-limit",
    "size:check": "size-limit --limit"
  },
  "size-limit": [
    {
      "path": "packages/core/dist/index.js",
      "limit": "12 KB",
      "name": "@upup/core (main)"
    },
    {
      "path": "packages/shared/dist/index.js",
      "limit": "20 KB",
      "name": "@upup/shared"
    },
    {
      "path": "packages/core/dist/steps/hash.js",
      "limit": "3 KB",
      "name": "@upup/core/steps/hash"
    },
    {
      "path": "packages/core/dist/steps/deduplicate.js",
      "limit": "3 KB",
      "name": "@upup/core/steps/deduplicate"
    }
  ],
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@size-limit/preset-small-lib": "^10.0.3",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^7.4.2",
    "size-limit": "^10.0.3",
    "turbo": "2.5.8"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "^4.3.2",
      "prismjs": "^1.29.0",
      "tough-cookie": "^4.1.3",
      "jsdom": "22.1.0",
      "node-notifier": "10.0.1",
      "node-fetch": "2.6.7",
      "rollup": "^4.0.0"
    }
  },
  "dependencies": {
    "@azure/msal-browser": "^5.6.3"
  }
}
