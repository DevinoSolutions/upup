{
    "$schema": "https://turbo.build/schema.json",
    "globalPassThroughEnv": [
        "MINIO_ROOT_USER",
        "MINIO_ROOT_PASSWORD",
        "UPUP_UPLOAD_TOKEN_SECRET",
        "UPUP_E2E_BUCKET",
        "UPUP_E2E_REGION",
        "UPUP_E2E_ENDPOINT",
        "S3_BUCKET",
        "S3_REGION",
        "S3_KEY_ID",
        "S3_SECRET",
        "S3_ENDPOINT",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "DROPBOX_CLIENT_ID",
        "DROPBOX_APP_SECRET",
        "ONEDRIVE_CLIENT_ID",
        "ONEDRIVE_CLIENT_SECRET",
        "DANGEROUSLY_BOOT_WITH_MISSING_REQUIRED_ENV_AND_SKIP_VALIDATION"
    ],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": [
                "dist/**",
                "dist-node/**",
                ".next/**",
                "build/**",
                "!.next/cache/**"
            ]
        },
        "@useupup/docs#build": {
            "dependsOn": ["^build"],
            "outputs": ["build/**", "../landing/public/documentation/**"]
        },
        "@useupup/landing#build": {
            "dependsOn": ["^build", "@useupup/docs#build"]
        },
        "@useupup/playground#build": {
            "dependsOn": ["^build"]
        },
        "build-storybook": {
            "dependsOn": ["^build"],
            "outputs": ["storybook-static/**"]
        },
        "@useupup/storybook-vanilla#build-storybook": {
            "dependsOn": ["^build"],
            "outputs": ["storybook-static/**"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": ["^build"]
        },
        "test": {
            "dependsOn": ["^test", "^build"]
        },
        "@useupup/vanilla#test": {
            "dependsOn": ["^test", "^build", "build"]
        },
        "@useupup/preact#test": {
            "dependsOn": ["^test", "^build", "build"]
        },
        "test:coverage": {
            "dependsOn": ["^build"]
        },
        "@useupup/vanilla#test:coverage": {
            "dependsOn": ["^build", "build"]
        },
        "@useupup/preact#test:coverage": {
            "dependsOn": ["^build", "build"]
        },
        "typecheck": {
            "dependsOn": ["^typecheck", "^build"]
        },
        "clean": {
            "cache": false
        }
    }
}
