{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": [
                "dist/**",
                "dist-node/**",
                ".next/**",
                "build/**",
                "!.next/cache/**"
            ]
        },
        "@upup/docs#build": {
            "dependsOn": ["^build"],
            "outputs": ["build/**", "../landing/public/documentation/**"]
        },
        "@upup/landing#build": {
            "dependsOn": ["^build", "@upup/docs#build"]
        },
        "@upup/playground#build": {
            "dependsOn": ["^build"]
        },
        "build-storybook": {
            "dependsOn": ["^build"],
            "outputs": ["storybook-static/**"]
        },
        "@upup/storybook-vanilla#build-storybook": {
            "dependsOn": ["^build"],
            "outputs": ["storybook-static/**"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": ["^build"]
        },
        "test": {
            "dependsOn": ["^test", "^build"]
        },
        "@upup/vanilla#test": {
            "dependsOn": ["^test", "^build", "build"]
        },
        "@upup/preact#test": {
            "dependsOn": ["^test", "^build", "build"]
        },
        "test:coverage": {
            "dependsOn": ["^build"]
        },
        "@upup/vanilla#test:coverage": {
            "dependsOn": ["^build", "build"]
        },
        "@upup/preact#test:coverage": {
            "dependsOn": ["^build", "build"]
        },
        "typecheck": {
            "dependsOn": ["^typecheck", "^build"]
        },
        "clean": {
            "cache": false
        }
    }
}
